[Unit]
Description=Varlink HTTP Bridge
DefaultDependencies=no
Conflicts=shutdown.target

[Service]
Type=simple
ExecStart=@bindir@/varlink-http-bridge --bind 0.0.0.0:1031
Restart=on-failure
RestartSec=5

[Install]
WantedBy=network.target
